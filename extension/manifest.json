{
  "manifest_version": 3,
  "name": "Aegis – Phishing Detection",
  "description": "AI-powered phishing detection using real-time URL analysis",
  "version": "1.0",
  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
